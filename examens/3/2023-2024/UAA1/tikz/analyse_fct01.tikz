\begin{tikzpicture}[baseline=(current bounding box.north)]
    % AXES + GRILLES
    \tkzInit[xmin=-8, xmax=5, ymin=-10,ymax=6]
    \tkzGrid
    \tkzDrawX[right=1pt]
    \tkzLabelX[font=\scriptsize, orig=false]
    \tkzDrawY[above=1pt]
    \tkzLabelY[font=\scriptsize, orig=false]
    % POINTS
   \tkzFct[domain=-7:-2]{(\x+6)*(\x+2)}
   \tkzFct[domain=-2:4]{-0.75*(\x+2)*(\x-2)}
   \draw[fill=white] (-7,5) circle (3pt);
   \draw[fill=black] (4,-9) circle (3pt);
\end{tikzpicture}