\begin{tikzpicture}
    \tkzDefPoint(0,0){A}
    \tkzDefPoint(0,5){B}
    \tkzDefPoint(3,0){C}
    \tkzDrawPolygon(A,B,C)
    \tkzMarkRightAngle(C,A,B)
    \tkzLabelSegment[align=center](A,B){Falaise\\\SI{70}{m}}
    \tkzLabelSegment(B,C){Corde}
    \tkzLabelSegment(C,A){Sol}
    \tkzMarkAngle(A,B,C)
    \tkzLabelAngle[pos=1.2](A,B,C){$\alpha$}
    \tkzLabelPoint[above](B){Départ}
    \tkzLabelPoint[right](C){Arrivée}
\end{tikzpicture}