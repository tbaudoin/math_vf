\begin{tikzpicture}
    \tkzDefPoint(0,0){A}
    \tkzDefPoint(0,-4){B}
    \tkzDefPoint(3,-4){C}
    \tkzDrawPolygon(A,B,C)
    \tkzLabelPoints[left](A)
    \tkzLabelPoints[below right](C)
    \tkzLabelPoints[below left](B)
    \tkzLabelSegment(A,C){$5$}
    \tkzLabelSegment[left](A,B){$x$} 
    \tkzLabelSegment[below](B,C){$7$}
    \tkzDrawPoints(A,B,C)
    \tkzMarkRightAngle[size=.5](A,B,C)
\end{tikzpicture}