\begin{tikzpicture}
    \tkzDefPoints{0/0/A, 0/3/B,4/0/C}
    \tkzDrawPolygon(A,B,C)
    \tkzMarkRightAngle(C,A,B)
    \tkzLabelSegment[left](A,B){$\dfrac{x}{5}$}
    \tkzLabelSegment[below](A,C){$x-1$}
    \tkzLabelSegment[above right](B,C){$x+1$}
    \tkzLabelPoints[below](A,C)
    \tkzLabelPoints[above](B)
\end{tikzpicture}