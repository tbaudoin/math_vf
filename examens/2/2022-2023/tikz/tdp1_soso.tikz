\begin{tikzpicture}[baseline=(current bounding box.north)]
    % Points
    \tkzDefPoint(0,0){A}
    \tkzDefPoint(30:3){C}    
    \tkzDefPoint(60:3){B}
    \tkzDefPoint(-20:3){D}
    \tkzDefPointsBy[rotation=center D angle 100](A,B,C){}
    \tkzDrawPolygon[color=\figcolor](A',B',C')
    \tkzDrawPolygon(A,B,C)
    \tkzDrawPoints(A,B,C,D)
    \tkzLabelPoints[left](A)
    \tkzLabelPoints[above](B)
    \tkzLabelPoints[right](C)
    \tkzLabelPoints(D)
\end{tikzpicture}