\begin{tikzpicture}[baseline=(current bounding box.north), scale=0.8]
    % Points
    \tkzDefPoints{0/0/A, 2/2/I, 2/3.5/M, 5/3.5/S}
    \tkzDefPointsBy[rotation=center A angle -80](A,M,I,S){}
    \tkzDrawPolygon[color=\figcolor](M',A',S',I')
    \tkzDrawPolygon(M,A,S,I)
    \tkzDrawPoints(A,M,I,S)
    \tkzLabelPoints[above](M)
    \tkzLabelPoints[left](A)
    \tkzLabelPoints[right](S)
    \tkzLabelPoints[above right](I)
\end{tikzpicture}