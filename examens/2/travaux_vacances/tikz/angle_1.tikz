\begin{tikzpicture}
    \tkzDefPoints{0/0/A, -1/0/LA, 1/0/RA}
    \tkzDefPoint(40:2){B}
    \tkzDrawLines(LA,RA A,B)
    \tkzDrawPoint(A)
    \tkzLabelPoints[below](A)
    \tkzMarkAngle[mark=none](RA,A,B)
    \tkzLabelAngle[pos=.5](RA,A,B){\scriptsize$1$}
    \tkzMarkAngle[size=.6, mark=none](B,A,LA)
    \tkzLabelAngle[pos=.3](B,A,LA){\scriptsize$2$}
\end{tikzpicture}