\begin{tikzpicture}[baseline=(current bounding box.north)]
    % Points
    \tkzDefPoint(0,0){A}
    \tkzDefPoint(-120:3){C}    
    \tkzDefPoint(-20:4){B}
    \tkzDefPoint(200:3){D}
    \tkzDefShiftPoint[D](0:6){E}
    % Image
    \tkzDefPointsBy[rotation = center B angle -75](A,B,C){}
    \tkzDrawPolygon[\figcolor](A',B',C')
    % Polygon
    \tkzDrawPolygon(A,B,C)    
    \tkzDrawPoints(A,B,C)    
    \tkzLabelPoints[above](A)
    \tkzLabelPoints[below](B,C)
\end{tikzpicture}