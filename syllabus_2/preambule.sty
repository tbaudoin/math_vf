% Balance en tikz pour les équations
\NewDocumentCommand{\balance}{O{2} m m}{
    \begin{tikzpicture}
        \def\l{#1}
        \coordinate (L) at (-\l, 0);
        \coordinate (R) at (\l,0);
        \coordinate (M) at (0,-0.02);
        \coordinate (LP) at (-\l,.25);
        \coordinate (RP) at (\l,.25);
        \coordinate (A) at (-120:0.75);
        \coordinate (B) at (-60:0.75);
        \draw (LP) -- (L) -- (R) -- (RP);

        % le triangle 
        \draw (A) -- (B) -- (M) -- cycle;
        \node at (barycentric cs:A=1,B=1,M=1){=};

        % plateau de gauche
        \node[anchor=south, inner sep=0pt] (LM) at (LP){#2};
        \draw ($(LM.south west) - (.25,0)$) -- ($(LM.south east) + (.25,0)$);
        % plateau de droite
        \node[anchor=south, inner sep=0pt] (RM) at (RP){#3};
        \draw ($(RM.south west) - (.25,0)$) -- ($(RM.south east) + (.25,0)$);
        %debug tool 
        %\draw (current bounding box.north west) rectangle (current bounding box.south east);
    \end{tikzpicture}
}


