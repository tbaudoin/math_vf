%==================================================
\NewDocumentCommand{\dotsforanswer}{m o O{1ex}}%
{%
    \IfNoValueTF{#2}%
    {
        \par
        \foreach \i in {1,...,#1}{\dotfill\vskip #3}
    }
    {
        #2\dotfill\vskip #3
        \foreach \i in {2,...,#1}{\dotfill\vskip #3}
    }
}
%===============================================================================
% \adf est l'abréviation de answer dotfill. La commande permet de créer une zone
% de réponse pour les élèves
% Utilisation : \adf{nombre de lignes} ou \adf[text]{nombre de lignes}
%===============================================================================
\NewDocumentCommand{\adf}{o m O{1 cm}}%
{%
    %
    \IfValueTF{#1}%
    %if True
    {%
        \begin{tikzpicture}[y=#3, baseline=(current bounding box.north)]%
            \node[inner sep=0,text width=\linewidth] at (0,0){#1 \dotfill};
            \foreach \y in {-1,...,-#2}{\node[text width=\linewidth, inner sep=0] at (0,\y){\dotfill};}
        \end{tikzpicture}\bigbreak%
    }%
    %if False
    {%
        \par%
        \begin{tikzpicture}[y=#3,baseline=(current bounding box.north)]%
            \foreach \y in {-1,...,-#2}{\node[text  width=\linewidth, inner sep=0] at (0,\y){\dotfill};}
        \end{tikzpicture}\bigbreak%
    }%
    %
}
