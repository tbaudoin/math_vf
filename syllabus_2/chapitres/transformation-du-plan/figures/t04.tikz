\begin{tikzpicture}
    \tkzDefPoints{0/0/A, -1/-1/B, 3/-2/C,2.5/2/D,1/-.5/E}
    \tkzDefPoints{1/-2/F, 3.5/-.5/G}
    \tkzDefPointsBy[translation=from F to G](A,B,C,D,E){}
    \tkzDrawPolygon[color=\corcolor](A',B',C',D',E')
    \tkzDrawPolygon(A,B,C,D,E)
    \tkzDrawPoints(A,B,C,D,E)
    \tkzLabelPoints[below](B,C)
    \tkzLabelPoints[above](A,D,E,F,G)
    \tkzDrawSegment[->, >=latex](F,G)
\end{tikzpicture}