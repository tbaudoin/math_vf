\begin{tikzpicture}
    \tkzDefPoints{0/0/A, 1/0/C, 3/0/D,0/-2/B}
    \tkzDefPointsBy[reflection=over B--D](A,B,C,D){}
    \tkzDrawPolygon[color=\corcolor](A',B',C')
    \tkzDrawSegment[color=\corcolor](C',D')
    \tkzDrawPolygon(A,B,C)
    \tkzDrawSegment(C,D)
    \tkzDrawPoints(A,B,C,D)
    \tkzLabelPoints[above](A,C,D)
    \tkzLabelPoints[below](B)
    \tkzLabelSegment[above](C,D){fig.~1}
\end{tikzpicture}