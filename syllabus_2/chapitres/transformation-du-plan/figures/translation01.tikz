\begin{tikzpicture}
    \tkzDefPoints{0/0/A, 1.5/2/B, 2/-1/C, 2/2/D, 3/0/E}
    \tkzDefPointsBy[translation=from D to E](A,B,C){}
    \tkzDrawPolygon[color=\corcolor](A',B',C')
    \tkzDrawPolygon(A,B,C)
    \tkzDrawPoints(A,B,C)
    \tkzLabelPoints[below left](A)
    \tkzLabelPoints[below](C,E)
    \tkzLabelPoints[above](B,D)
    \tkzDrawSegment[->, >=latex](D,E)
\end{tikzpicture}