\begin{tikzpicture}
    \tkzDefPoints{0/0/A, 0/-2/D, 2/-2/E}
    \tkzDefPoint(45:2.5){B}
    \tkzDefPoint(30:2){C}
    \tkzDefPointsBy[translation=from D to E](A,B,C){}
    \tkzDrawPolygon[color=\corcolor](A',B',C')
    \tkzDrawPolygon(A,B,C)
    \tkzDrawPoints(A,B,C)
    \tkzLabelPoints[left](A,D)
    \tkzLabelPoints[right](C,E)
    \tkzLabelPoints[above](B)
    \tkzDrawSegment[->, >=latex](D,E)
\end{tikzpicture}