\begin{tikzpicture}
    \tkzDefPoints{0/0/A, 1.5/2/B, 2/1.5/C}
    \tkzDefPoints{-1/-.5/D, 3/-1/E}
    \tkzDefPointsBy[reflection=over D--E](A,B,C){}
    \tkzDrawPolygon[color=white](A',B',C')
    \tkzDrawPolygon(A,B,C)
    \tkzDrawPoints(A,B,C)
    \tkzDrawSegment(D,E)
    \tkzLabelPoints[below left](A)
    \tkzLabelPoints[below](C)
    \tkzLabelPoints[above](B)
    \tkzLabelPoint[above](E){$f$}
\end{tikzpicture}