\begin{tikzpicture}
    \tkzDefPoints{0/0/A,0/-3/B,2/0/C,0/-1/D,-1/-1.2/E,1.8/-1.5/F}
    \tkzDefPointsBy[symmetry= center F](A,B,C,D,E){}
    \draw[color=\corcolor](C')--(A')--(D')--(B');
    \draw[color=\corcolor](D')--(E');
    \draw(C)--(A)--(D)--(B);
    \draw(D)--(E);
    \tkzDrawPoints(A,B,C,D,E,F)
    \tkzLabelPoints[above](A,C,E,F)
    \tkzLabelPoints[below](B)
    \tkzLabelPoints[right](D)
\end{tikzpicture}