\begin{tikzpicture}[scale=.8]
    \tkzDefPoints{0/1/A,3/4/B,4/0/C,3/2/D}
    \tkzDefPointsBy[rotation=center A angle 90](A,B,C,D){}
    \tkzDrawPolygon[color=\corcolor](A',B',C',D')
    \tkzDrawPolygon(A,B,C,D)
    \tkzDrawPoints(A,B,C,D)
    \tkzLabelPoints[below left](A)
    \tkzLabelPoints[above](B)
    \tkzLabelPoints[below right](C)
    \tkzLabelPoints[below left=1ex and -1ex](D)
\end{tikzpicture}