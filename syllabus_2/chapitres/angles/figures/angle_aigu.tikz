\begin{tikzpicture}[baseline=(current bounding box.east)]
    \tkzDefPoints{0/0/A,2/0/B}
    \tkzDefPoint(30:2){C}
    \tkzFillAngle[fill=red!20](B,A,C)
    \tkzMarkAngle[mark=none](B,A,C)
    \tkzDrawLine[add=0 and .5](A,B)
    \tkzDrawLine[add=0 and .5](A,C)
    \tkzDrawPoints(A,B,C)
    \tkzLabelPoints[below](A,B)
    \tkzLabelPoints[above](C)
\end{tikzpicture}