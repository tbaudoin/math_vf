\begin{tikzpicture}[baseline=(current bounding box.east), scale=.5]
    \tkzDefPoint(0,0){B}
    \tkzDefPoint(60:2){C}
    \tkzDefPoint(-10:2){D}
    \tkzDefPoint(110:2){A}
    \tkzDefPoint(160:2){E}
    \tkzDrawLines[add=0 and .3](B,D B,C B,A B,E)
    \tkzDrawPoints(A,B,C,D,E)
    \tkzLabelPoints[left](A)
    \tkzLabelPoints[below](B)
    \tkzLabelPoints[right](C)
    \tkzLabelPoints[below](D)
    \tkzLabelPoints[below](E)
