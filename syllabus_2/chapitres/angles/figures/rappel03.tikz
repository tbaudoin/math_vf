\begin{tikzpicture}[baseline=(current bounding box.east), scale=.6]
    \tkzDefPoint(0,0){D}
    \tkzDefPoint(-10:2){E}
    \tkzDefPoint(-160:2){C}
    \tkzDrawLines[add=0 and .3](D,C D,E)
    \tkzMarkAngle[mark=none, size=0.5](C,D,E)
    \tkzDrawPoints(D,C,E)
    \tkzLabelPoints[above](D)
    \tkzLabelPoints[above](C)
    \tkzLabelPoints[above](E)
\end{tikzpicture}