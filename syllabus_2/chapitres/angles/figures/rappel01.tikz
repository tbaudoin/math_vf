\begin{tikzpicture}[baseline=(current bounding box.east), scale=.7]
    \tkzDefPoint(0,0){B}
    \tkzDefPoint(-40:1){C}
    \tkzDefPoint(-160:1){A}
    \tkzDrawLines[add=0 and 1](B,A B,C)
    \tkzMarkAngle[mark=none, size=0.5](A,B,C)
    \tkzDrawPoints(A,B,C)
    \tkzLabelPoints[above](A)
    \tkzLabelPoints[above](B)
    \tkzLabelPoints[above](C)
\end{tikzpicture}