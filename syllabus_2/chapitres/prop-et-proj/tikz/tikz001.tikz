\begin{tikzpicture}[>=latex]
    % Axes
    \draw[->] (0,-0.20) -- (0,30) node[above] {$Prix$ (€)};
    \draw[->] (-0.20,0) -- (50,0) node[right] {$Temps$ (min)};
    % Grille
    \draw[gray, dotted] (0,0) grid (50,30);
    % Graduations
    \foreach \x in {5,10,...,50}
        {
            \draw (\x,-0.1) -- (\x,0.1) node[below=2pt] {\x};
        }
    \foreach \y in {5,10,...,30}
        {
            \draw (-0.1,\y) -- (0.1,\y) node[left=2pt] {\y};
        }
\end{tikzpicture}