\begin{tikzpicture}
    \tkzDefPoint(0,0){A}
    \tkzDefPoint(3,0){B}
    \tkzDefPoint(60:3){C}
    \tkzDrawPolygon(A,B,C)
    \tkzMarkAngles[mark = |, size=.5](C,B,A A,C,B B,A,C)
    \tkzLabelAngles(C,B,A A,C,B B,A,C){$60\degres$}
    \tkzMarkSegments[mark=||](A,B B,C A,C)
    \tkzLabelPoints[above](C)
    \tkzLabelPoints[below](A,B)
\end{tikzpicture}