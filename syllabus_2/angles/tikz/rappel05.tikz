
\begin{tikzpicture}[baseline=(current bounding box.east), scale=.5]
    \tkzDefPoint(0,0){B}
    \tkzDefPoint(90:2){A}
    \tkzDefPoint(210:2){A'}
    \tkzDefPoint(150:2){C}
    \tkzDrawLines[add=0 and .3](B,A B,A' B,C)
    \tkzLabelLine[pos=1.3,above](B,C){f}
    \tkzMarkAngle[mark=none, size=0.5](A,B,A')
    \tkzDrawPoints(A,A',B,C)
    \tkzLabelPoints[right](A)
    \tkzLabelPoints[below](A')
    \tkzLabelPoints[below](B)
    \tkzLabelPoints[below](C)
\end{tikzpicture}