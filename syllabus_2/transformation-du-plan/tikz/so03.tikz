\begin{tikzpicture}
    \tkzDefPoints{0/0/C,2/0/F,4/-2/E,-1/-2/D}
    \tkzDefPoints{-2/-1.3/X, 5/-1.3/Y}
    \tkzDefPointsBy[reflection=over X--Y](C,D,E,F){}
    \tkzDrawPolygon[color=\corcolor](C',D',E',F')
    \tkzDrawPolygon(C,D,E,F)
