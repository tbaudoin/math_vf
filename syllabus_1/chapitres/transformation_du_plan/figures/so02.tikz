\begin{tikzpicture}
    \tkzDefPoints{0/0/A}
    \tkzDefPoint(45:2.5){B}
    \tkzDefPoint(20:2){C}
    \tkzDefPointsBy[reflection=over A--C](A,B,C){}
    \tkzDrawPolygon[color=\corcolor](A',B',C')
    \tkzDrawPolygon(A,B,C)
    \tkzDrawPoints(A,B,C)
    \tkzLabelPoints[left](A)
    \tkzLabelPoints[right](C)
    \tkzLabelPoints[above](B)
\end{tikzpicture}