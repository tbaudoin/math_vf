\begin{tikzpicture}
    \tkzDefPoints{0/0/A}
    \tkzDefPoint(30:2){B}
    \tkzDefPoint(120:2){C}
    \tkzDefPointWith[colinear=at C,K=1.5](A,B)
    \tkzGetPoint{D}
    \tkzDefPointsBy[reflection=over C--D](A,B){}
    \tkzDrawSegment[color=\corcolor](A',B')
    \tkzDrawLine(C,D)
    \tkzDrawSegment(A,B)
    \tkzDrawPoints(A,B,C,D)
    \tkzLabelPoints[below](A,B,C,D)
\end{tikzpicture}